  "slug": "french-present-conjugation",
  "title": "French Present Tense Conjugation",
  "description": "Regular -er/-ir/-re endings, spelling changes, and key irregular verbs",
  "questionCount": 54,
  "crashCourse": {
    "title": "Present tense conjugation",
    "subtitle": "Build the present tense from regular endings, then memorize the high-frequency irregulars.",
    "sections": [
      {
        "title": "Regular -er verbs",
        "content": "Drop -er and add: -e, -es, -e, -ons, -ez, -ent.",
        "tip": "parler → je parle, tu parles, il parle, nous parlons, vous parlez, ils parlent."
      },
      {
        "title": "Regular -ir verbs like finir",
        "content": "Drop -ir and add: -is, -is, -it, -issons, -issez, -issent.",
        "tip": "The plural forms have -iss-: nous finissons, vous finissez, ils finissent."
      },
      {
        "title": "Regular -re verbs like vendre",
        "content": "Drop -re and add: -s, -s, nothing, -ons, -ez, -ent.",
        "tip": "vendre → je vends, tu vends, il vend, nous vendons, vous vendez, ils vendent."
      },
      {
        "title": "Spelling-change verbs",
        "content": "-ger keeps e before -ons; -cer uses ç before -ons; acheter/appeler/espérer change spelling before silent endings.",
        "tip": "nous mangeons, nous commençons, j’achète, j’appelle, j’espère."
      },
      {
        "title": "Irregular essentials",
        "content": "être, avoir, aller, faire, prendre, venir, pouvoir, vouloir, devoir, dire, voir, savoir are too common to skip.",
        "tip": "Pay special attention to vous faites, vous dites, ils vont, ils font."
      }
    ]
  },
