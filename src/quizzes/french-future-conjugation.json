{
  "slug": "french-future-conjugation",
  "title": "French Futur Simple Conjugation",
  "description": "Future endings, regular stems, -re stems, and common irregular future stems",
  "questionCount": 48,
  "crashCourse": {
    "title": "Futur simple",
    "subtitle": "One set of endings for every verb; some verbs use an irregular stem.",
    "sections": [
      {
        "title": "Endings",
        "content": "The futur simple endings are always -ai, -as, -a, -ons, -ez, -ont.",
        "tip": "They look like avoir in the present: ai, as, a, avons/ons, avez/ez, ont."
      },
      {
        "title": "Regular stems",
        "content": "For -er and -ir verbs, add the ending to the infinitive.",
        "tip": "parler → je parlerai; finir → nous finirons."
      },
      {
        "title": "-re verbs",
        "content": "For regular -re verbs, drop the final e, then add the future endings.",
        "tip": "vendre → je vendrai; attendre → ils attendront."
      },
      {
        "title": "Irregular stems",
        "content": "The endings stay regular, but the stem changes.",
        "tip": "être → ser-, avoir → aur-, aller → ir-, faire → fer-, voir → verr-, pouvoir → pourr-, vouloir → voudr-, venir → viendr-."
      }
    ]
  },
