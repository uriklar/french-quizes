  "slug": "french-imparfait-conjugation",
  "title": "French Imparfait Conjugation",
  "description": "Nous-stem formation, imparfait endings, être exception, and spelling traps",
  "questionCount": 48,
  "crashCourse": {
    "title": "Imparfait conjugation",
    "subtitle": "Almost everything follows one rule: present nous form minus -ons + imparfait endings.",
    "sections": [
      {
        "title": "The rule",
        "content": "Take the present-tense nous form, drop -ons, add -ais, -ais, -ait, -ions, -iez, -aient.",
        "tip": "nous parlons → je parlais; nous finissons → tu finissais; nous prenons → il prenait."
      },
      {
        "title": "être exception",
        "content": "être is the only fully irregular imparfait stem: ét-.",
        "tip": "j’étais, tu étais, il était, nous étions, vous étiez, ils étaient."
      },
      {
        "title": "-ger / -cer spelling",
        "content": "-ger keeps e before a-endings; -cer keeps ç before a-endings.",
        "tip": "je mangeais, nous mangions; je commençais, nous commencions."
      },
      {
        "title": "-ier verbs",
        "content": "If the stem ends in i, nous/vous have double i.",
        "tip": "étudier → nous étudiions, vous étudiiez."
      }
    ]
  },
